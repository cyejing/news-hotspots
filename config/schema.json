{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "News Hotspots Split Config Schema",
  "version": "6.0.0",
  "definitions": {
    "sourceBase": {
      "type": "object",
      "required": ["id", "type", "name", "enabled", "priority", "topic"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["rss", "twitter", "github", "reddit"] },
        "name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "priority": { "type": "integer", "minimum": 1, "maximum": 10 },
        "topic": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "rssSource": {
      "allOf": [
        { "$ref": "#/definitions/sourceBase" },
        {
          "type": "object",
          "required": ["url"],
          "properties": {
            "type": { "const": "rss" },
            "url": { "type": "string" }
          }
        }
      ]
    },
    "twitterSource": {
      "allOf": [
        { "$ref": "#/definitions/sourceBase" },
        {
          "type": "object",
          "required": ["handle"],
          "properties": {
            "type": { "const": "twitter" },
            "handle": { "type": "string" }
          }
        }
      ]
    },
    "githubSource": {
      "allOf": [
        { "$ref": "#/definitions/sourceBase" },
        {
          "type": "object",
          "required": ["repo"],
          "properties": {
            "type": { "const": "github" },
            "repo": { "type": "string" }
          }
        }
      ]
    },
    "redditSource": {
      "allOf": [
        { "$ref": "#/definitions/sourceBase" },
        {
          "type": "object",
          "required": ["subreddit"],
          "properties": {
            "type": { "const": "reddit" },
            "subreddit": { "type": "string" }
          }
        }
      ]
    },
    "topic": {
      "type": "object",
      "required": ["id", "emoji", "label", "description", "search", "display"],
      "properties": {
        "id": { "type": "string" },
        "emoji": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "search": { "type": "object" },
        "display": {
          "type": "object",
          "required": ["max_items"],
          "properties": {
            "max_items": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "apiSource": {
      "type": "object",
      "required": ["id", "name", "enabled", "topic", "priority"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "topic": { "type": "string" },
        "priority": { "type": "integer", "minimum": 1, "maximum": 10 }
      }
    },
    "runtime": {
      "type": "object",
      "required": ["pipeline", "fetch", "diagnostics", "cache"],
      "properties": {
        "pipeline": { "type": "object" },
        "fetch": { "type": "object" },
        "diagnostics": { "type": "object" },
        "cache": { "type": "object" }
      }
    }
  },
  "properties": {
    "rss": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "array",
          "items": { "$ref": "#/definitions/rssSource" }
        }
      }
    },
    "twitter": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "array",
          "items": { "$ref": "#/definitions/twitterSource" }
        }
      }
    },
    "github": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "array",
          "items": { "$ref": "#/definitions/githubSource" }
        }
      }
    },
    "reddit": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "array",
          "items": { "$ref": "#/definitions/redditSource" }
        }
      }
    },
    "topics": {
      "type": "object",
      "properties": {
        "topics": {
          "type": "array",
          "items": { "$ref": "#/definitions/topic" }
        }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "array",
          "items": { "$ref": "#/definitions/apiSource" }
        }
      }
    },
    "runtime": { "$ref": "#/definitions/runtime" }
  }
}
